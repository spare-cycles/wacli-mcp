{
  "name": "wacli-mcp",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "MCP server wrapping the wacli WhatsApp CLI",
  "bin": {
    "wacli-mcp": "dist/server.js"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --import tsx --test send-file.test.ts",
    "check": "npm run format:check && npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0"
  }
}
